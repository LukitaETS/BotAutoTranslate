<header class="site-header">
  <div class="nav-shell">
    <a href="/" class="brand">
      <span class="brand-mark">DL</span>
      <span>Discord Language Bot</span>
    </a>

    <nav class="nav-actions">
      <% if (currentUser) { %>
        <a class="ghost-button" href="/dashboard">Dashboard</a>
        <div class="user-chip">
          <% if (currentUser.avatar) { %>
            <img
              src="https://cdn.discordapp.com/avatars/<%= currentUser.id %>/<%= currentUser.avatar %>.png?size=64"
              alt="<%= currentUser.username %>"
            />
          <% } %>
          <span><%= currentUser.global_name || currentUser.username %></span>
        </div>
        <form method="post" action="/auth/logout">
          <button type="submit" class="ghost-button">Cerrar sesión</button>
        </form>
      <% } else { %>
        <a class="primary-button" href="/auth/login">Entrar con Discord</a>
      <% } %>
    </nav>
  </div>
</header>
